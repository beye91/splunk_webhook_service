# Splunk Webhook Admin Platform - Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# Database Configuration
# ============================================
POSTGRES_DB=webhook_admin
POSTGRES_USER=webhook
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# ============================================
# Security Keys
# ============================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your_jwt_secret_here

# ============================================
# Service Ports
# ============================================
CONFIG_API_PORT=8000
WEBHOOK_PORT=5000
ADMIN_UI_PORT=3000

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ============================================
# Admin UI Configuration
# ============================================
# URL where the Config API is accessible from the browser
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# Optional: External Ollama Host
# ============================================
# If Ollama is running on a different host, set these
# OLLAMA_HOST=http://192.168.1.100
# OLLAMA_PORT=11434
